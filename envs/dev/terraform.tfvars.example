# Copy this file to terraform.tfvars and update with your values\n\nenvironment  = \"dev\"\nlocation     = \"Central India\"\nproject_name = \"event-driven\"\n\n# Authorized IP ranges for AKS API access (CIDR format)\naks_authorized_ips = [\n  # \"203.0.113.0/24\"  # Example: Your organization's IP range\n]\n\ntags = {\n  \"Managed-By\"   = \"Terraform\"\n  \"Cost-Center\"  = \"Engineering\"\n  \"Compliance\"   = \"SOC2\"\n  \"Owner\"        = \"Platform-Team\"\n  \"Backup\"       = \"true\"\n}\n