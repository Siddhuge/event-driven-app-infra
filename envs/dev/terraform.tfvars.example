environment  = "dev"
location     = "Central India"
project_name = "event-driven"
created_date = "2026-04-29"

aks_private_cluster_enabled             = true
aks_private_cluster_public_fqdn_enabled = true

# Used only if aks_private_cluster_enabled is set to false.
aks_authorized_ips = []

# Enable this to create an SSH jumpbox in the AKS VNet.
jumpbox_enabled = false

# Required when jumpbox_enabled is true.
jumpbox_admin_username       = "azureuser"
jumpbox_admin_ssh_public_key = "ssh-rsa REPLACE_WITH_YOUR_PUBLIC_KEY"
jumpbox_allowed_ssh_cidrs    = ["REPLACE_WITH_YOUR_PUBLIC_IP/32"]

tags = {
  "Managed-By"  = "Terraform"
  "Cost-Center" = "Engineering"
  "Compliance"  = "SOC2"
  "Owner"       = "Platform-Team"
  "Backup"      = "true"
}
